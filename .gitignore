# 忽略文件配置 / Git Ignore
# Binaries
*.exe
*.exe~
*.dll
*.so
*.dylib
backend/server
backend/jeje_web

# Go components
backend/vendor/

# Node components
node_modules/
npm-debug.log*

# IDEs
.vscode/
.idea/
*.swp
*.swo

# OS files
Thumbs.db
.DS_Store

# Environment variables (敏感文件)
.env
backend/.env

# Uploads & Runtime Storage
storage/uploads/*
!storage/uploads/.gitkeep

# DB data
db_data/
mysql_data/
