# ========== 环境变量示例配置文件 / Environment Variables Example ==========
# 说明：请将此文件复制并重命名为 .env，然后根据实际情况修改配置信息

# ---------- 应用基础配置 ----------
# 运行环境: dev (开发), prod (生产)
APP_ENV=prod
# 监听地址与端口
APP_ADDR=:8080

# ========== 数据库配置 / DATABASE CONFIG (SQLite) ==========
# 数据库名称/文件名
DB_NAME=jeje_web.db

# ---------- 安全与会话配置 ----------
# JWT 签名密钥 (请务必在生产环境中修改此项)
JWT_SECRET=please-change-this-to-a-random-string
# 是否开启 Cookie 保护 (生产环境开启 HTTPS 后设为 true)
COOKIE_SECURE=false

# ---------- 管理员初始化配置 ----------
# 是否开启管理员自动初始化逻辑
ADMIN_BOOTSTRAP=true
# 初始化管理员账号
ADMIN_USER=admin
# 初始化管理员密码
ADMIN_PASS=admin123

# ---------- 跨域与网络配置 ----------
# 允许的跨域来源列表
CORS_ORIGINS=http://localhost:8080
# 信任的代理前缀
TRUSTED_PROXIES=0.0.0.0/0
# 前端文件存放路径
FRONTEND_DIR=../frontend

# ---------- 频率限制与安全保护 ----------
# 频率限制窗口时间 (秒)
RATE_LIMIT_WINDOW_SECONDS=60
# 窗口内最大请求次数
RATE_LIMIT_MAX=5
# 留言内容长度上限
MESSAGE_MAX_LEN=1000
# 昵称长度上限
NICKNAME_MAX_LEN=50
# 留言后的冷却等待时间 (秒)
MESSAGE_COOLDOWN_SECONDS=10
# 验证码有效时长 (秒)
CAPTCHA_TTL_SECONDS=300
# 登录最大重试次数
LOGIN_MAX_ATTEMPTS=5
# 登录失败锁定时间 (分钟)
LOGIN_LOCK_MINUTES=15

# ---------- 文件上传配置 ----------
# 文件上传物理存储路径
UPLOAD_DIR=../storage/uploads
# 文件访问 URL 基础路径
UPLOAD_BASE_URL=/uploads
# 最大允许上传大小 (MB)
UPLOAD_MAX_MB=1024
